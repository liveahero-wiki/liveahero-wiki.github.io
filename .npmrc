# pnpm 11 supply-chain trust check: ignore "downgrade" warnings for packages
# published more than a minute ago (i.e. all established transitive deps such as
# semver@6.3.1, which simply predates provenance attestation). Without this,
# install/build fails with ERR_PNPM_TRUST_DOWNGRADE.
#trust-policy-ignore-after=1

# Don't re-run an install check (which re-triggers the trust gate) before
# `pnpm dev`/`build`.
verify-deps-before-run=false
